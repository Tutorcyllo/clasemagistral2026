<script>
function switchTab(id, btn) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById('panel-' + id).classList.add('active');
  btn.classList.add('active');
}
function toggleA(header) {
  const body = header.nextElementSibling;
  const isOpen = header.classList.contains('open');
  document.querySelectorAll('.a-header').forEach(h => h.classList.remove('open'));
  document.querySelectorAll('.a-body').forEach(b => b.classList.remove('open'));
  if (!isOpen) { header.classList.add('open'); body.classList.add('open'); }
}
</script>
